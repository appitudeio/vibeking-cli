{
  "name": "@vibeking/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./scoring": "./src/scoring.ts",
    "./titles": "./src/titles.ts",
    "./roasts": "./src/roasts.ts",
    "./redaction": "./src/redaction.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "echo \"@vibeking/core is source-only — consumers bundle via tsup/vite\"",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@vibeking/tsconfig": "workspace:*",
    "typescript": "^5.6.3",
    "vitest": "^3.0.5"
  }
}
