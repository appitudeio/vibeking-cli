{
  "name": "vibeking",
  "version": "0.0.1",
  "description": "The leaderboard for vibe coders. Scan your Claude Code burn, claim your title, defend the crown.",
  "type": "module",
  "bin": {
    "vibeking": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "keywords": [
    "claude",
    "claude-code",
    "leaderboard",
    "tokens",
    "vibe-coding"
  ],
  "license": "MIT",
  "dependencies": {
    "@vibeking/core": "workspace:*",
    "picocolors": "^1.1.1",
    "valibot": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@vibeking/tsconfig": "workspace:*",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
