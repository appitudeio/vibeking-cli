{
  "name": "vibeking",
  "version": "0.1.0",
  "description": "The leaderboard for vibe coders. Scan your Claude Code burn, claim your title, defend the crown.",
  "type": "module",
  "bin": {
    "vibeking": "dist/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/appitudeio/vibeking-cli.git"
  },
  "homepage": "https://vibeking.io",
  "bugs": {
    "url": "https://github.com/appitudeio/vibeking-cli/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "TZ=UTC vitest run",
    "sync-marketplace": "tsx scripts/sync-marketplace.ts",
    "clean": "rm -rf dist *.tsbuildinfo",
    "pack:test": "pnpm build && rm -rf /tmp/vibeking-pack && mkdir -p /tmp/vibeking-pack && npm pack --pack-destination /tmp/vibeking-pack --silent && node scripts/print-pack-instructions.mjs",
    "release": "node scripts/release.mjs",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "keywords": [
    "claude",
    "claude-code",
    "leaderboard",
    "tokens",
    "vibe-coding"
  ],
  "license": "MIT",
  "dependencies": {
    "picocolors": "^1.1.1",
    "valibot": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "eslint": "^9.17.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^3.0.5"
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  }
}
